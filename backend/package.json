{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build:vercel": "bun build src/vercel-entry.ts --outfile '../api/index.js' --target node --format cjs --bundle --minify",
    "studio": "cloud-studio --port 3001 --hostname 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@hono/node-server": "1.12.0",
    "@supabase/supabase-js": "^2.106.0",
    "@vibecodeapp/backend-sdk": "^1.0.1",
    "@vibecodeapp/cloud-studio": "^0.2.4",
    "@vibecodeapp/proxy": "^2.0.3",
    "hono": "4.6.0",
    "resend": "^6.12.3",
    "ws": "^8.20.1",
    "zod": "4.1.11"
  }
}
